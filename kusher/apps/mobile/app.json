{
  "expo": {
    "name": "kusher-app",
    "slug": "kusher",
    "scheme": "kusher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kalwhyte.kusherapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0f14"
      },
      "package": "com.kalwhyte.kusherapp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-dev-client"
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "packagerOpts": {
      "projectRoots": [
        "./"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5adb209d-7d34-49da-aec2-347e2bda460f",

        "buildRoot": "apps/mobile"
      }
    }
  }
}
