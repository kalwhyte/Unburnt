{
  "expo": {
    "name": "Chimney",
    "slug": "chimney",
    "scheme": "chimney",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kalwhyte.kusherapp"
    },
    "android": {
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_WIFI_STATE",
        "CHANGE_NETWORK_STATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_WIFI_STATE",
        "CHANGE_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0f14"
      },
      "package": "com.kalwhyte.kusherapp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#0d0f14",
          "androidMode": "default"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-dev-client",
      "expo-secure-store"
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "buildRoot": "apps/mobile",
        "projectId": "584aec1c-b2a2-400c-9afc-efe9ad89ed92"
      }
    },
    "owner": "kalwhyte",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/584aec1c-b2a2-400c-9afc-efe9ad89ed92"
    }
  }
}
