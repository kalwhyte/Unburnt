{
  "expo": {
    "name": "kusher-app",
    "slug": "kusher-app",
    "scheme": "kusher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kalwhyte.kusherapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0f14"
      },
      "package": "com.kalwhyte.kusherapp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-dev-client"
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "packagerOpts": {
      "projectRoots": ["./"]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f177301-a19f-49f9-a690-30fa44ed503d",
        "buildRoot": "apps/mobile"
      }
    }
  }
}
